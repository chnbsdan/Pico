{
  "env": {
    "FOLDER_WALLPAPER": "wallpaper",
    "FOLDER_COVER": "cover"
  },
  "functions": {
    "api/upload.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/manage", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
